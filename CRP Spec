# 9. Module Registration
 
Both sensory systems and cognitive modules register with the workspace using:
 
```typescript
interface CRPModuleRegistration {
  module_id: string;                    // Unique ID, e.g., "era.core.safety"
  module_type: ModuleType;              // Classification
  layer: "sense" | "affect" | "cognition";  // Which architectural layer (v0.2.0)
  subscribes_to: ("broadcast" | "direct")[];
  direct_channels: string[];            // Module IDs this module can send DIRECT to
  can_override: boolean;                // Only true for safety-critical modules
  max_response_time_ms: number;
  default_priority: number;             // 0.0-1.0, before affect/twin modulation
  affect_sensitivity: AffectSensitivity;
  capabilities: string[];               // For discovery/debugging
  required_context: string[];           // Sensory outputs this module needs
}
```
 
```typescript
type ModuleType =
  | "sense"       // Layer 0: sensory transduction
  | "affect"      // Layer 1: emotional pre-processing
  | "safety"      // Layer 2: can override (privacy, compliance)
  | "task"        // Layer 2: workflow identification
  | "anomaly"     // Layer 2: deviation detection
  | "learning"    // Layer 2: pattern identification
  | "domain"      // Layer 2: vertical-specific (clinical, finance, legal)
  | "intent"      // Layer 2: goal inference
  | "social"      // Layer 2: collaboration context
```
 
